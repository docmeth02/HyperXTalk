<?xml version="1.0" encoding="utf-8"?>
<!--
  libopenssl3.vcxproj
  Utility project: runs setup-openssl3.ps1 the first time to produce
      prebuilt/unpacked/openssl3/x86_64-win32-v142_static_{Debug,Release}/
  Subsequent builds are no-ops (SkipIfExists guard in the script).
-->
<Project DefaultTargets="Build" ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|Win32">
      <Configuration>Debug</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Fast|Win32">
      <Configuration>Fast</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Fast|x64">
      <Configuration>Fast</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{C3D45678-90AB-CDEF-1234-567890ABCDEF}</ProjectGuid>
    <RootNamespace>libopenssl3</RootNamespace>
  </PropertyGroup>

  <!-- Fallback SolutionDir when not building via the .sln -->
  <PropertyGroup Label="UserMacros"/>
  <PropertyGroup Condition="!Exists('$(SolutionDir)livecode.sln')">
    <SolutionDir>$(MSBuildThisFileDirectory)..\..\..\</SolutionDir>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props"/>

  <PropertyGroup Label="Configuration">
    <ConfigurationType>Utility</ConfigurationType>
    <PlatformToolset>v142</PlatformToolset>
    <CharacterSet>MultiByte</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props"/>
  <ImportGroup Label="ExtensionSettings"/>
  <ImportGroup Label="PropertySheets">
    <Import Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')"
            Label="LocalAppDataPlatform"
            Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props"/>
  </ImportGroup>

  <PropertyGroup>
    <!-- Resolve absolute paths immediately so cmd /c if not exist gets a clean path with no .. traversal -->
    <OpenSSL3DebugLib>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\..\..\prebuilt\unpacked\openssl3\x86_64-win32-v142_static_Debug\lib\libcrypto.lib'))</OpenSSL3DebugLib>
    <OpenSSL3ReleaseLib>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\..\..\prebuilt\unpacked\openssl3\x86_64-win32-v142_static_Release\lib\libcrypto.lib'))</OpenSSL3ReleaseLib>
    <SetupScript>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\..\..\build-win-x86_64\setup-openssl3.ps1'))</SetupScript>
  </PropertyGroup>

  <!-- Custom build step: verify libs are present (run build-openssl3.bat manually first) -->
  <ItemDefinitionGroup>
    <CustomBuildStep>
      <Command>if exist "$(OpenSSL3DebugLib)" exit /b 0
echo.
echo ERROR: OpenSSL 3 static libs not found.
echo Run build-win-x86_64\build-openssl3.bat in a VS2019 Developer Command Prompt first.
echo.
exit /b 1</Command>
      <Outputs>$(OpenSSL3DebugLib)</Outputs>
      <Inputs>$(SetupScript)</Inputs>
      <Message>Checking OpenSSL 3 static libs...</Message>
    </CustomBuildStep>
  </ItemDefinitionGroup>

  <ItemGroup>
    <None Include="$(SetupScript)">
      <DeploymentContent>false</DeploymentContent>
    </None>
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets"/>
  <ImportGroup Label="ExtensionTargets"/>
</Project>
